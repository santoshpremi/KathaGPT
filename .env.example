# KathaGPT local development — copy to .env and fill in values.
# .env is gitignored; never commit real API keys.

# OpenRouter (primary LLM provider — same pattern as chartStudio)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
SITE_URL=http://localhost:5173
SITE_NAME=KathaGPT

# Direct provider keys (optional — used when OpenRouter is not configured)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=  # alias for GEMINI_API_KEY
PERPLEXITY_API_KEY=

# Frontend: auto-use Rust API when /api/local/health responds (set false to force Node tRPC)
# VITE_USE_RUST_API=true
